{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "pull-request-title-pattern": "chore: release ${component} v${version}",
  "packages": {
    ".": {
      "release-type": "go",
      "component": "synclet",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "deploy/helm/synclet/Chart.yaml",
          "glob": false
        }
      ]
    },
    "connectors/source-google-sheets": {
      "release-type": "go",
      "component": "source-google-sheets",
      "changelog-path": "CHANGELOG.md"
    },
    "connectors/destination-google-sheets": {
      "release-type": "go",
      "component": "destination-google-sheets",
      "changelog-path": "CHANGELOG.md"
    },
    "connectors/source-mysql": {
      "release-type": "go",
      "component": "source-mysql",
      "changelog-path": "CHANGELOG.md"
    },
    "connectors/destination-bigquery": {
      "release-type": "go",
      "component": "destination-bigquery",
      "changelog-path": "CHANGELOG.md"
    },
    "deploy/helm/synclet": {
      "release-type": "helm",
      "component": "synclet-helm",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
